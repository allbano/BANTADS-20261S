# Porta do API Gateway
PORT=3000

# Chave secreta para validação de JWT (deve ser idêntica à do ms-auth)
JWT_SECRET=change-me-in-production

# URLs dos microsserviços
MS_AUTH_URL=http://bantads-ms-auth:8085
MS_CLIENTE_URL=http://bantads-ms-cliente:8080
MS_CONTA_URL=http://bantads-ms-conta:8080
MS_FUNCIONARIO_URL=http://bantads-ms-funcionario:8080
